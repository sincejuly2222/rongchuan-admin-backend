# 运行环境，常用 development / production
NODE_ENV=development

# 服务监听端口
PORT=3000

# 允许跨域访问的前端地址，必须和前端实际 origin 完全一致
CORS_ORIGIN=http://localhost:5173

# MySQL 主机地址，本机可用 127.0.0.1，远程库填写真实 IP 或域名
DB_HOST=127.0.0.1
# MySQL 端口，默认 3306
DB_PORT=3306
# MySQL 用户名
DB_USER=root
# MySQL 密码
DB_PASSWORD=your_password
# 业务数据库名
DB_NAME=rongchuan_admin

# Access Token 的签名密钥，生产环境必须替换为高强度随机字符串
ACCESS_TOKEN_SECRET=replace_with_a_long_random_string
# Access Token 的时长，jsonwebtoken 支持如 2h / 30m / 7d
ACCESS_TOKEN_EXPIRES_IN=2h
# Access Token 的秒数，返回给前端的 expiresIn 就来自这里
ACCESS_TOKEN_EXPIRES_IN_SECONDS=7200

# Refresh Token 的签名密钥，建议与 Access Token 使用不同密钥
REFRESH_TOKEN_SECRET=replace_with_a_different_long_random_string
# Refresh Token 的时长
REFRESH_TOKEN_EXPIRES_IN=7d
# Refresh Token 的秒数
REFRESH_TOKEN_EXPIRES_IN_SECONDS=604800

# 刷新令牌 Cookie 名称
REFRESH_COOKIE_NAME=refreshToken
# 是否只允许 HTTPS 发送 Cookie，生产环境通常为 true
REFRESH_COOKIE_SECURE=false
# Cookie 的 SameSite 策略，常用 lax / none / strict
REFRESH_COOKIE_SAME_SITE=lax
# Cookie 绑定的域名，留空表示当前域
REFRESH_COOKIE_DOMAIN=
# Cookie 生效路径，当前项目默认只在 /api/auth 下使用
REFRESH_COOKIE_PATH=/api/auth
# Cookie 有效期，单位毫秒，这里是 7 天
REFRESH_COOKIE_MAX_AGE=604800000
